# URL CSV de uma planilha Google Sheets compartilhada como
# "Qualquer pessoa com o link — Leitor". Formato:
#   https://docs.google.com/spreadsheets/d/<ID>/export?format=csv
# Colunas esperadas (primeira linha = cabeçalho):
#   date,title,type,discipline,description
#   - date: AAAA-MM-DD
#   - type: prova | entrega | evento | prazo
#   - discipline: código da disciplina (ex. ELT231) — opcional
#   - description: detalhes do evento (local, horário, matéria) — opcional
VITE_CALENDAR_SHEET_CSV_URL=

# Link do Google Form de contribuição de material (Archive) e de eventos
# (Calendário), usado nos banners de CTA.
VITE_CONTRIBUTE_FORM_URL=

# --- Página de upload (/upload) — usadas só pela function api/upload-init.js,
# nunca expostas ao navegador (sem prefixo VITE_). Configure no dashboard da
# Vercel (Project Settings → Environment Variables), não precisa em .env
# local a menos que você rode a function com `vercel dev`.

# ID da pasta raiz no Drive (mesma de DRIVE_ROOT_FOLDER_ID usada no sync).
DRIVE_ROOT_FOLDER_ID=

# Autenticação via OAuth da conta Google DONA da pasta raiz (não service
# account — service accounts não têm cota de armazenamento própria e não
# conseguem escrever num "Meu Drive" pessoal, só em Shared Drives do
# Workspace). Client ID/Secret vêm de um OAuth Client tipo "App para
# computador" no Google Cloud Console. O refresh token é gerado uma vez,
# localmente, com:
#   node --env-file=.env scripts/get-drive-refresh-token.mjs
# (veja esse script pro passo a passo completo)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# Senha compartilhada que protege o formulário de upload.
UPLOAD_ACCESS_PASSWORD=
